{
  "appId": "dev.ogra.desktop",
  "productName": "Ogra Desktop",
  "asar": true,
  "asarUnpack": [
    "node_modules/better-sqlite3/**"
  ],
  "directories": {
    "output": "release"
  },
  "files": [
    "dist-electron/**/*",
    "dist/renderer/**/*"
  ],
  "mac": {
    "target": "dmg",
    "hardenedRuntime": true,
    "category": "public.app-category.productivity",
    "artifactName": "${productName}-${version}-mac.${ext}"
  },
  "win": {
    "target": "nsis",
    "artifactName": "${productName}-${version}-win.${ext}"
  },
  "linux": {
    "target": "AppImage",
    "category": "Office",
    "artifactName": "${productName}-${version}-linux.${ext}",
    "desktop": {
      "Categories": "Office;Utility;",
      "MimeType": "x-scheme-handler/ogra;"
    }
  },
  "protocols": {
    "name": "Ogra Desktop",
    "schemes": ["ogra"]
  }
}
